{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SimpleFile",
  "version": "1.1.0",
  "identifier": "com.simplefile.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix frontend run build",
    "beforeBuildCommand": "npm --prefix frontend run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "SimpleFile - File Explorer",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob:; media-src 'self' data: blob:; object-src 'self' blob:; base-uri 'none'; form-action 'none'; frame-src 'none'; frame-ancestors 'none'; worker-src 'none'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "targets": ["deb"],
    "createUpdaterArtifacts": true,
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1"]
      }
    },
    "fileAssociations": [
      {
        "name": "Folder",
        "ext": [],
        "mimeType": "inode/directory",
        "description": "Open folder in SimpleFile"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVFMzlCMTlDOUY0NkUxMzUKUldRMTRVYWZuTEU1N3Q2aGRScWdBRVVDTE1nVmg4SGI3ajJPdXhjcmhFaE1aSm02VW5pSnV2RjQK",
      "endpoints": [
        "https://github.com/conniecombs/SimpleFile-Svelte/releases/latest/download/latest.json"
      ]
    }
  }
}
